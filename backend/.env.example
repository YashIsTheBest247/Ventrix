# ── Ventrix backend config ────────────────────────────────────────────────
# Copy this file to ".env" and fill in what you need. Everything is optional;
# the app runs without any of it (Gmail + email reminders just stay disabled).

# Where the SQLite file lives (default: ./hackify.db)
DATABASE_URL=sqlite:///./hackify.db

# Comma-separated origins allowed to call the API (the Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Email reminders (SMTP) ────────────────────────────────────────────────
# Leave blank to disable outbound email. For Gmail SMTP use an App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Ventrix <no-reply@ventrix.local>

# Who gets the reminder emails (usually your own address)
REMINDER_EMAIL=

# Send reminders this many days before a deadline (comma-separated)
REMINDER_DAYS_BEFORE=7,3,1

# ── Watchlist alerts (fire on NEW hackathons after each scrape) ────────────
# In-app always; also emailed if SMTP above is configured. First scrape of an
# empty DB is treated as a baseline (no flood); only later arrivals alert.
ALERT_NEW_AI=true          # a new AI/ML hackathon appears
ALERT_BIG_PRIZE=true       # prize pool over ALERT_PRIZE_MIN (USD, "$" amounts)
ALERT_PRIZE_MIN=10000
ALERT_REMOTE=true          # a new remote/online hackathon opens
AUTO_SCRAPE_HOURS=6        # background re-scrape interval (0 = disabled)

# ── Gmail inbox scan (OAuth) ──────────────────────────────────────────────
# LOCAL (dev): download an OAuth "Desktop app" client and save it as
# backend/google_client_secret.json. Leave the web vars below blank — the local
# desktop consent flow will be used.
GOOGLE_CLIENT_SECRET_FILE=google_client_secret.json
GOOGLE_TOKEN_FILE=google_token.json

# PRODUCTION (web OAuth): the secret file isn't deployed, so paste the OAuth
# *Web* client JSON here (whole {"web":{...}} object on one line), and set the
# redirect URI to https://<your-backend>/api/gmail/callback (also add that exact
# URL as an Authorized redirect URI in the Google Cloud Web client).
GOOGLE_CLIENT_SECRET_JSON=
GMAIL_REDIRECT_URI=
# Where to send the browser after the OAuth callback (your Vercel URL in prod):
FRONTEND_URL=http://localhost:5173

# ── AI problem-statement analyzer (all free) ──────────────────────────────
# Leave everything blank to use the built-in heuristic analyzer (no key needed).
# Set ONE of the following for real AI analysis, all free:
#   1) Google Gemini  — free key: https://aistudio.google.com/apikey
#   2) Groq           — free key: https://console.groq.com/keys
#   3) Ollama         — local, free: https://ollama.com  (then `ollama pull llama3.1`)
AI_PROVIDER=auto                 # auto | gemini | groq | ollama | none
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_URL=                      # e.g. http://localhost:11434
OLLAMA_MODEL=llama3.1
